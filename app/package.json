{
  "name": "uni-display-updater",
  "version": "1.0.1",
  "description": "UniFi Connect Display — Protect App Updater",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.hackpig1974.unidisplayupdater",
    "productName": "Uni Display Updater",
    "win": {
      "target": "portable",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities"
    },
    "portable": {
      "artifactName": "UniDisplayUpdater-portable.exe"
    },
    "dmg": {
      "artifactName": "UniDisplayUpdater.dmg"
    },
    "files": [
      "src/**/*",
      "node_modules/**/*"
    ]
  },
  "keywords": [],
  "author": "Damon Downing",
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Hackpig1974/unifi-connect-display-fix.git"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "electron-store": "^8.1.0"
  }
}
